{
  "name": "space-combat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"*.{json,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"*.{json,html}\"",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "npx playwright test"
  },
  "lint-staged": {
    "*.{ts,css,json,html}": "prettier --write",
    "*.ts": [
      "eslint --no-warn-ignored",
      "bash -c 'tsc --noEmit'"
    ]
  },
  "dependencies": {
    "@babylonjs/core": "^8.52.0",
    "@babylonjs/loaders": "^8.52.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^5.4.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1"
  }
}
